# Context7 MCP
CONTEXT7_API_KEY=ctx7sk-your-api-key
CONTEXT7_PROXY_PROVIDER=cloudflare
CONTEXT7_PROXY_URL=https://context7-proxy.<your-domain>.workers.dev
PROXY_KEY=replace-with-your-proxy-key

# Cloudflare Worker cache defaults
CACHE_TTL_SECONDS=3600
SEARCH_CACHE_TTL_SECONDS=21600

# Cloudflare Worker rate limiting defaults
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
